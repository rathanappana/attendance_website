# ─── SERVER ───────────────────────────────────────────────
PORT=3000
BASE_URL=https://your-domain.com
SESSION_SECRET=change-me-to-a-long-random-string

# ─── ADMIN AUTH ───────────────────────────────────────────
ADMIN_PASSWORD=your-admin-password
TOTP_SECRET=YOUR_BASE32_TOTP_SECRET   # run setup.js to generate
# Admin login mode toggle → edit settings.js (usePasswordFallback)

# ─── GOOGLE OAUTH ─────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── GOOGLE SHEETS ────────────────────────────────────────
# Path to service account JSON key file (keep this file out of git!)
GOOGLE_CREDENTIALS_FILE=credentials.json
# From the Google Sheets URL: /spreadsheets/d/<SPREADSHEET_ID>/
SPREADSHEET_ID=your-spreadsheet-id
